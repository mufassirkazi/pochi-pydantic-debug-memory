# ── Logfire write token ────────────────────────────────────────────────────
#
# IMPORTANT: This must be a WRITE token, not a read/query token.
# Read tokens (used for MCP) will be rejected by the OTLP ingest endpoint
# with "401 Unknown token" even though they work for log queries.
#
# Generate a write token at:
#   https://logfire.pydantic.dev/<org>/<project>/settings/write-tokens/
#
# The token in .logfire/logfire_credentials.json is typically a write token
# but may expire. If OTLP exports are silently failing, check the console
# for "OTLPExporterError: Unauthorized" — that confirms a token problem.

LOGFIRE_TOKEN=

# ── Optional overrides ─────────────────────────────────────────────────────
OTEL_SERVICE_NAME=lumina-ai
PORT=3000
SESSION_SECRET=lumina-dev-secret-change-in-prod
